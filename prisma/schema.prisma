// =============================================================================
// PlayBite — Prisma Schema (Phase 2: Full Database Design)
// PostgreSQL · Prisma 7
//
// Datasource URL is configured in prisma.config.ts (Prisma 7 convention).
// The datasource block here declares the provider only.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

/// User roles across the platform
enum UserRole {
  PLATFORM_ADMIN
  RESTAURANT_OWNER
  RESTAURANT_STAFF
  CUSTOMER
}

/// Subscription plan tiers available to restaurant groups
enum PlanTier {
  FREE_TRIAL
  STARTER
  GROWTH
  PROFESSIONAL
  ENTERPRISE
}

/// Lifecycle states for a restaurant group's subscription
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

/// Physical presence verification method used when a customer checks in
enum CheckInMethod {
  QR_CODE
  NFC_TAG
  WIFI
  BLUETOOTH_BEACON
  STAFF_MANUAL
}

/// Status of a customer's visit/check-in session
enum VisitStatus {
  ACTIVE     // Customer is currently in-session
  COMPLETED  // Session ended normally
  EXPIRED    // Session timed out
  FLAGGED    // Anti-cheat flagged; under review
}

/// Lifecycle of a game play session
enum GameSessionStatus {
  STARTED
  COMPLETED
  ABANDONED
  INVALID    // Rejected by anti-cheat engine
}

/// Current state of a game in the catalog
enum GameStatus {
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  ARCHIVED
}

/// Category a game belongs to (used for filtering and analytics)
enum GameCategoryType {
  PUZZLE
  TRIVIA
  ARCADE
  SPEED
  MEMORY
  QUIZ
  REACTION
  SPORTS
  CASUAL
  OTHER
}

/// Types of reward a customer can receive
enum RewardType {
  DISCOUNT_PERCENT
  DISCOUNT_FIXED
  FREE_ITEM
  BUY_ONE_GET_ONE
  SPIN_WHEEL
  BADGE
  POINTS_MULTIPLIER
  CASHBACK
  GIFT_VOUCHER
  MYSTERY
}

/// Lifecycle state of a reward claim
enum ClaimStatus {
  PENDING
  REDEEMED
  EXPIRED
  VOIDED
}

/// Delivery channel for a notification
enum NotificationChannel {
  SMS
  PUSH
  IN_APP
  EMAIL
}

/// Whether an audit log entry records a write or a security event
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  OTP_REQUESTED
  OTP_VERIFIED
  OTP_FAILED
  PERMISSION_DENIED
  ANTI_CHEAT_FLAG
  REWARD_ISSUED
  REWARD_REDEEMED
}

// =============================================================================
// PLATFORM — Admin & Subscription
// =============================================================================

/// Platform-wide administrator. Has unrestricted access to all tenants.
/// Soft-deleted via deletedAt rather than hard removal to preserve audit trail.
model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  avatarUrl String?
  isActive  Boolean   @default(true)
  deletedAt DateTime? // soft delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  auditLogs AuditLog[]
  accounts  Account[]

  @@index([email])
  @@index([deletedAt])
  @@map("admins")
}

/// A named commercial subscription plan with feature flags.
/// Plans are managed by platform admins and assigned to restaurant groups.
model SubscriptionPlan {
  id          String   @id @default(uuid())
  name        String   @unique
  tier        PlanTier
  description String?
  /// Monthly price in smallest currency unit (e.g. cents)
  priceMonthly Int
  /// Annual price (cents) — null means no annual option
  priceAnnual  Int?
  /// Trial duration in days (0 = no trial)
  trialDays    Int      @default(14)
  /// Maximum number of restaurant branches allowed
  maxBranches Int      @default(1)
  /// Maximum monthly active customers (0 = unlimited)
  maxMonthlyCustomers Int @default(0)
  /// Maximum number of games a group can activate
  maxGames    Int      @default(3)
  /// Maximum staff accounts
  maxStaff    Int      @default(2)
  /// Maximum spin-wheel prizes configurable
  maxPrizes   Int      @default(5)
  /// Whether leaderboard features are included
  hasLeaderboard Boolean @default(false)
  /// Whether analytics dashboard is included
  hasAnalytics   Boolean @default(false)
  /// Whether CSV/PDF export is available
  hasExport      Boolean @default(false)
  /// Whether priority support is included
  hasPrioritySupport Boolean @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@index([tier])
  @@map("subscription_plans")
}

/// A restaurant group's active subscription to a plan.
/// One group has exactly one subscription at a time (enforced by unique FK).
model Subscription {
  id                 String             @id @default(uuid())
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  /// External payment provider subscription ID (e.g. Stripe sub_xxx)
  externalId         String?            @unique
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  planId            String
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])

  restaurantGroupId String          @unique
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  invoices Invoice[]

  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

// =============================================================================
// RESTAURANT GROUP — Multi-branch chain support
// =============================================================================

/// Top-level grouping entity. Independent restaurants have exactly one group.
/// All customer identity, points, and leaderboards are scoped to a group.
model RestaurantGroup {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  logoUrl     String?
  /// Whether this is a chain (multiple restaurants) or independent
  isChain     Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  restaurants   Restaurant[]
  customers     Customer[]
  owners        RestaurantOwner[]
  subscription  Subscription?
  rewards       Reward[]
  spinPrizes    SpinWheelPrize[]
  leaderboards  DailyLeaderboard[]
  weeklyBoards  WeeklyLeaderboard[]
  lifetimeBoard LifetimeLeaderboard?
  dailyAnalytics DailyAnalytics[]
  leaderboardConfig LeaderboardConfig?
  monthlyBoards   MonthlyLeaderboard[]
  spinWheelConfig SpinWheelConfig?
  leaderboardRewardRules LeaderboardRewardRule[]
  weeklyMetrics   WeeklyMetrics[]
  monthlyMetrics  MonthlyMetrics[]
  onboarding      OnboardingProgress?
  challenges      Challenge[]
  tournaments     Tournament[]
  seasonalEvents  SeasonalEvent[]
  luckyHours      LuckyHour[]
  campaigns       Campaign[]
  levelConfigs    LevelConfig[]
  achievements    Achievement[]
  posIntegrations POSIntegration[]
  whiteLabelConfig WhiteLabelConfig?
  ssoConfigs       SSOConfig[]
  ipRestrictions   IPRestriction[]
  apiKeys          APIKey[]
  webhookEndpoints WebhookEndpoint[]
  integrations     Integration[]

  @@index([slug])
  @@index([deletedAt])
  @@map("restaurant_groups")
}

/// A brand/business entity. Belongs to one group. Has one or more branches.
model Restaurant {
  id          String    @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  branches  Branch[]
  staff     RestaurantStaff[]
  owners    RestaurantOwner[]
  settings  RestaurantSettings?

  @@index([restaurantGroupId])
  @@index([deletedAt])
  @@map("restaurants")
}

/// A physical location. Check-ins, sessions, and leaderboards are branch-scoped.
model Branch {
  id        String    @id @default(uuid())
  name      String
  address   String?
  city      String?
  country   String    @default("US")
  /// IANA timezone identifier, e.g. "America/New_York"
  timezone  String    @default("UTC")
  latitude  Float?
  longitude Float?
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  staffAssignments StaffBranchAssignment[]
  visits           RestaurantVisit[]
  checkInSessions  CheckInSession[]
  restaurantGames  RestaurantGame[]
  dailyLeaderboards DailyLeaderboard[]
  gameSessions     GameSession[]
  qrCodes          RestaurantQRCode[]
  nfcTags          RestaurantNFCTag[]
  checkInLogs      CheckInLog[]

  @@index([restaurantId])
  @@index([deletedAt])
  @@index([isActive])
  @@map("branches")
}

/// Per-restaurant configuration: spin wheel rules, anti-cheat thresholds, etc.
model RestaurantSettings {
  id                      String  @id @default(uuid())
  /// Max visit session duration in minutes
  maxSessionMinutes       Int     @default(360)
  /// Max game plays per customer per day
  maxPlaysPerDay          Int     @default(10)
  /// Max points a customer can earn per day
  maxPointsPerDay         Int     @default(5000)
  /// QR token rotation interval in minutes (5–1440)
  qrRotationMinutes       Int     @default(60)
  /// Whether NFC check-in is enabled
  nfcEnabled              Boolean @default(false)
  /// Whether Wi-Fi check-in is enabled
  wifiEnabled             Boolean @default(false)
  /// Whether Bluetooth beacon check-in is enabled
  beaconEnabled           Boolean @default(false)
  /// Minimum plausible game duration in seconds (anti-cheat)
  minGameDurationSeconds  Int     @default(5)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("restaurant_settings")
}

// =============================================================================
// RESTAURANT USERS — Owner & Staff
// =============================================================================

/// Owner of a restaurant group. Can manage all restaurants in their group.
model RestaurantOwner {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  phone     String?
  avatarUrl String?
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  restaurants Restaurant[]
  accounts    Account[]

  @@index([restaurantGroupId])
  @@index([email])
  @@index([deletedAt])
  @@map("restaurant_owners")
}

/// Staff member assigned to one or more branches. Limited operational access.
model RestaurantStaff {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  phone     String?
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  branchAssignments StaffBranchAssignment[]
  accounts          Account[]

  @@index([restaurantId])
  @@index([deletedAt])
  @@map("restaurant_staff")
}

/// Many-to-many join table scoping staff to specific branches.
model StaffBranchAssignment {
  id        String   @id @default(uuid())
  /// Whether this assignment grants redemption permission
  canRedeem Boolean  @default(true)
  createdAt DateTime @default(now())

  staffId  String
  staff    RestaurantStaff @relation(fields: [staffId], references: [id])
  branchId String
  branch   Branch          @relation(fields: [branchId], references: [id])

  @@unique([staffId, branchId])
  @@index([branchId])
  @@map("staff_branch_assignments")
}

// =============================================================================
// CUSTOMER — Identity, Profile & Device
// =============================================================================

/// Core customer identity, scoped per restaurant group.
/// Same phone number in two different groups = two separate Customer rows.
model Customer {
  id            String    @id @default(uuid())
  /// Encrypted at rest (AES-256) — stored as ciphertext
  phoneNumber   String
  displayHandle String?
  /// Total lifetime points across all visits to this group
  totalPoints   Int       @default(0)
  isActive      Boolean   @default(true)
  isBanned      Boolean   @default(false)
  banReason     String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  profile          CustomerProfile?
  devices          CustomerDevice[]
  visits           RestaurantVisit[]
  checkInSessions  CheckInSession[]
  gameSessions     GameSession[]
  rewardClaims     RewardClaim[]
  spinHistory      SpinHistory[]
  leaderboardEntries DailyLeaderboardEntry[]
  notifications    Notification[]
  deviceSessions   DeviceSession[]
  activityLogs     CustomerActivity[]
  accounts         Account[]
  deviceFingerprints DeviceFingerprint[]
  personalBests    PersonalBest[]
  weeklyEntries    WeeklyLeaderboardEntry[]
  monthlyEntries   MonthlyLeaderboardEntry[]
  lifetimeEntries  LifetimeLeaderboardEntry[]
  leaderboardFlags LeaderboardFlag[]
  winnerHistory    WinnerHistory[]
  challengeProgress ChallengeProgress[]
  referralsMade    Referral[]          @relation("ReferralsMade")
  referralsReceived ReferralRedemption[] @relation("ReferralsReceived")
  tournamentParticipations TournamentParticipant[]
  aiRecommendations AIRecommendation[]
  walletItems      WalletItem[]
  achievementUnlocks AchievementUnlock[]
  consentRecords   ConsentRecord[]

  /// Phone is unique per group; same phone can exist in multiple groups
  @@unique([phoneNumber, restaurantGroupId])
  @@index([restaurantGroupId])
  @@index([totalPoints])
  @@index([deletedAt])
  @@index([isBanned])
  @@map("customers")
}

/// Optional extended profile data for a customer.
model CustomerProfile {
  id          String    @id @default(uuid())
  firstName   String?
  lastName    String?
  email       String?
  dateOfBirth DateTime?
  avatarUrl   String?
  /// Customer's marketing opt-in preference
  marketingConsent Boolean @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  @@map("customer_profiles")
}

/// Tracks physical devices used by a customer. Used for fraud detection.
model CustomerDevice {
  id           String   @id @default(uuid())
  /// Hashed device fingerprint (not stored in plain text)
  deviceHash   String
  userAgent    String?
  ipAddress    String?
  /// Last time this device was seen
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, deviceHash])
  @@index([deviceHash])
  @@index([ipAddress])
  @@map("customer_devices")
}

// =============================================================================
// VISIT SYSTEM — Check-in & Session
// =============================================================================

/// Records every customer visit to a branch. The outer envelope of a session.
model RestaurantVisit {
  id         String      @id @default(uuid())
  status     VisitStatus @default(ACTIVE)
  /// Points earned during this visit
  pointsEarned Int       @default(0)
  checkInAt  DateTime    @default(now())
  checkOutAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])

  checkInSession CheckInSession?
  gameSessions   GameSession[]

  @@index([customerId])
  @@index([branchId])
  @@index([status])
  @@index([checkInAt])
  @@map("restaurant_visits")
}

/// Captures how a customer verified physical presence for a visit.
/// One CheckInSession per RestaurantVisit.
model CheckInSession {
  id               String        @id @default(uuid())
  method           CheckInMethod
  /// Raw artifact token presented (e.g. QR token value) — hashed for storage
  artifactHash     String?
  verifiedAt       DateTime      @default(now())
  expiresAt        DateTime
  /// IP address at time of check-in
  ipAddress        String?
  createdAt        DateTime      @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])
  visitId    String   @unique
  visit      RestaurantVisit @relation(fields: [visitId], references: [id])

  @@index([customerId])
  @@index([branchId])
  @@index([method])
  @@index([verifiedAt])
  @@map("check_in_sessions")
}

// =============================================================================
// GAMES — Catalog, Activation & Play Sessions
// =============================================================================

/// A category grouping for games displayed in the catalog.
model GameCategory {
  id          String           @id @default(uuid())
  name        String           @unique
  type        GameCategoryType
  description String?
  iconUrl     String?
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  games Game[]

  @@map("game_categories")
}

/// A game in the platform catalog. Modular HTML5 games approved by platform admin.
model Game {
  id              String     @id @default(uuid())
  name            String
  slug            String     @unique
  description     String?
  thumbnailUrl    String?
  /// Path or CDN URL where the game's HTML5 bundle is hosted
  bundleUrl       String
  /// Semantic version of the game bundle (e.g. "1.3.0")
  version         String     @default("1.0.0")
  status          GameStatus @default(PENDING_REVIEW)
  /// Difficulty 1 (easy) – 5 (hard)
  difficulty      Int        @default(2)
  /// Estimated play time in seconds
  estimatedPlaySecs Int      @default(60)
  /// Maximum achievable score — used for anti-cheat plausibility checks
  maxScore        Int        @default(1000000)
  /// Minimum realistic play duration in seconds — anti-cheat lower bound
  minDurationSecs Int        @default(5)
  /// Points awarded per unit of score (numerator of score→points ratio)
  pointsPerScore  Float      @default(1.0)
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  categoryId String
  category   GameCategory @relation(fields: [categoryId], references: [id])

  restaurantGames RestaurantGame[]
  gameSessions    GameSession[]
  personalBests   PersonalBest[]
  gameMetrics     GameMetrics[]

  @@index([status])
  @@index([slug])
  @@index([deletedAt])
  @@map("games")
}

/// Activation record: which games a restaurant branch has enabled.
/// Restaurant owners enable games from the catalog per branch.
model RestaurantGame {
  id             String   @id @default(uuid())
  isActive       Boolean  @default(true)
  /// Custom max plays per customer per day for this branch (overrides group setting)
  maxPlaysPerDay Int?
  /// Score multiplier for this branch (e.g. 2.0 = double points)
  scoreMultiplier Float   @default(1.0)
  /// Whether this game is featured/pinned at the top of the list
  isFeatured     Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  gameId   String
  game     Game   @relation(fields: [gameId], references: [id])
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  @@unique([gameId, branchId])
  @@index([branchId, isActive])
  @@map("restaurant_games")
}

/// A single play of a game by a customer. Score is validated server-side.
model GameSession {
  id          String            @id @default(uuid())
  status      GameSessionStatus @default(STARTED)
  /// Server-issued nonce to prevent score replay attacks
  nonce       String            @unique
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  /// Actual duration in seconds (computed from start/end)
  durationSecs Int?
  /// Raw score submitted by the client
  rawScore    Int?
  /// Validated final score (null if session did not complete cleanly)
  finalScore  Int?
  /// Points awarded to the customer for this session
  pointsAwarded Int             @default(0)
  /// Anti-cheat flag reason if status = INVALID
  flagReason  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])
  visitId    String
  visit      RestaurantVisit @relation(fields: [visitId], references: [id])

  score GameScore?

  @@index([customerId])
  @@index([gameId])
  @@index([branchId])
  @@index([visitId])
  @@index([status])
  @@index([startedAt])
  @@map("game_sessions")
}

/// Validated, immutable record of a game's final score. Written once on completion.
model GameScore {
  id        String   @id @default(uuid())
  score     Int
  createdAt DateTime @default(now())

  sessionId String      @unique
  session   GameSession @relation(fields: [sessionId], references: [id])

  @@index([score])
  @@map("game_scores")
}

// =============================================================================
// LEADERBOARD — Daily, Weekly & Lifetime
// =============================================================================

/// Daily leaderboard header for one branch or for the whole group.
/// One row per (group or branch) per calendar day.
model DailyLeaderboard {
  id       String   @id @default(uuid())
  /// The local calendar date this board covers (YYYY-MM-DD, stored in UTC midnight)
  date     DateTime
  isFrozen Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])
  /// Null means this is the group-wide board; non-null means branch-scoped board
  branchId          String?
  branch            Branch?         @relation(fields: [branchId], references: [id])

  entries DailyLeaderboardEntry[]

  @@unique([restaurantGroupId, branchId, date])
  @@index([restaurantGroupId, date])
  @@index([branchId, date])
  @@map("daily_leaderboards")
}

/// One row per customer per daily leaderboard. Updated on each point event.
model DailyLeaderboardEntry {
  id          String   @id @default(uuid())
  points      Int      @default(0)
  rank        Int?
  updatedAt   DateTime @updatedAt

  leaderboardId String
  leaderboard   DailyLeaderboard @relation(fields: [leaderboardId], references: [id])
  customerId    String
  customer      Customer         @relation(fields: [customerId], references: [id])

  @@unique([leaderboardId, customerId])
  @@index([leaderboardId, points])
  @@index([customerId])
  @@map("daily_leaderboard_entries")
}

/// Weekly aggregate leaderboard per restaurant group.
model WeeklyLeaderboard {
  id            String   @id @default(uuid())
  /// ISO week start date (Monday)
  weekStartDate DateTime
  isFrozen      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  entries WeeklyLeaderboardEntry[]

  @@unique([restaurantGroupId, weekStartDate])
  @@index([restaurantGroupId, weekStartDate])
  @@map("weekly_leaderboards")
}

/// Lifetime leaderboard — one per restaurant group, continuously updated.
model LifetimeLeaderboard {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurantGroupId String          @unique
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  entries LifetimeLeaderboardEntry[]

  @@map("lifetime_leaderboards")
}

// =============================================================================
// REWARDS — Spin Wheel, Coupons & Claims
// =============================================================================

/// A reward definition configured by a restaurant owner.
/// Can be a spin-wheel prize, leaderboard reward, or achievement badge.
model Reward {
  id          String     @id @default(uuid())
  name        String
  description String?
  type        RewardType
  /// For DISCOUNT_PERCENT: 0–100. For DISCOUNT_FIXED: amount in cents.
  value       Float?
  imageUrl    String?
  /// Total remaining inventory; null = unlimited
  inventory   Int?
  isActive    Boolean    @default(true)
  expiresAt   DateTime?
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  claims      RewardClaim[]
  spinPrizes  SpinWheelPrize[]
  leaderboardRules LeaderboardRewardRule[]
  winnerHistory    WinnerHistory[]
  rewardMetrics    RewardMetrics[]
  challenges       Challenge[]

  @@index([restaurantGroupId, isActive])
  @@index([type])
  @@index([deletedAt])
  @@map("rewards")
}

/// An instance of a reward issued to a customer.
/// Contains the redemption code shown to the customer.
model RewardClaim {
  id             String      @id @default(uuid())
  status         ClaimStatus @default(PENDING)
  /// Unique alphanumeric code shown to customer for redemption
  redemptionCode String      @unique
  issuedAt       DateTime    @default(now())
  redeemedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  rewardId   String
  reward     Reward   @relation(fields: [rewardId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, status])
  @@index([redemptionCode])
  @@index([expiresAt])
  @@map("reward_claims")
}

/// A coupon code that can be linked to a reward claim.
model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique
  description String?
  /// Maximum number of times this coupon can be used total
  maxUses     Int?
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

/// One slot on a spin wheel. Each prize has a probability weight.
model SpinWheelPrize {
  id         String   @id @default(uuid())
  label      String
  /// Relative probability weight (0.0–1.0). All prizes for a group must sum to 1.0.
  probability Float
  /// Remaining inventory for this prize; null = unlimited
  inventory  Int?
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])
  rewardId          String
  reward            Reward          @relation(fields: [rewardId], references: [id])

  spinHistory SpinHistory[]

  @@index([restaurantGroupId, isActive])
  @@map("spin_wheel_prizes")
}

/// Immutable record of every spin wheel outcome.
model SpinHistory {
  id         String   @id @default(uuid())
  /// Cryptographically seeded draw seed for audit trail
  drawSeed   String?
  spunAt     DateTime @default(now())

  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id])
  prizeId    String
  prize      SpinWheelPrize @relation(fields: [prizeId], references: [id])

  @@index([customerId])
  @@index([prizeId])
  @@index([spunAt])
  @@map("spin_history")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

/// A notification sent or queued for a customer.
model Notification {
  id        String              @id @default(uuid())
  channel   NotificationChannel
  title     String
  body      String
  isRead    Boolean             @default(false)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

/// Per-customer preference for each notification channel.
model NotificationPreference {
  id        String              @id @default(uuid())
  channel   NotificationChannel
  isEnabled Boolean             @default(true)
  updatedAt DateTime            @updatedAt

  /// Stored as customerId directly rather than FK to keep this table light
  customerId String

  @@unique([customerId, channel])
  @@index([customerId])
  @@map("notification_preferences")
}

// =============================================================================
// ANALYTICS
// =============================================================================

/// Daily aggregate metrics per restaurant group. Pre-computed for fast dashboard reads.
model DailyAnalytics {
  id               String   @id @default(uuid())
  date             DateTime
  totalVisits      Int      @default(0)
  uniqueCustomers  Int      @default(0)
  totalGamePlays   Int      @default(0)
  totalPointsAwarded Int    @default(0)
  totalRewardsIssued Int    @default(0)
  totalRewardsRedeemed Int  @default(0)
  totalSpins       Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@unique([restaurantGroupId, date])
  @@index([restaurantGroupId, date])
  @@map("daily_analytics")
}

/// Fine-grained per-customer activity log for engagement analytics.
model CustomerActivity {
  id         String   @id @default(uuid())
  eventType  String   // e.g. "VISIT", "GAME_PLAY", "SPIN", "REWARD_CLAIM"
  metadata   Json?    // flexible payload per event type
  occurredAt DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, eventType])
  @@index([occurredAt])
  @@map("customer_activity")
}

// =============================================================================
// SECURITY — Audit Log & Device Session
// =============================================================================

/// Immutable audit trail for every write operation and security event.
model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  /// Table or resource type affected, e.g. "Customer", "Reward"
  entityType String
  /// UUID of the affected row
  entityId   String?
  /// Actor who performed the action — UUID from any user table
  actorId    String?
  actorRole  UserRole?
  /// IP address of the request
  ipAddress  String?
  /// JSON snapshot of changed fields (before/after)
  diff       Json?
  /// Human-readable justification (required for admin overrides)
  note       String?
  occurredAt DateTime    @default(now())

  adminId String?
  admin   Admin?  @relation(fields: [adminId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([occurredAt])
  @@index([action])
  @@map("audit_logs")
}

/// Active authenticated device sessions for customers.
/// Used for single-session enforcement and fraud detection.
model DeviceSession {
  id           String   @id @default(uuid())
  /// Hashed JWT token identifier
  tokenHash    String   @unique
  ipAddress    String?
  userAgent    String?
  /// IANA timezone of the device at session creation
  deviceTz     String?
  expiresAt    DateTime
  revokedAt    DateTime?
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([expiresAt])
  @@index([tokenHash])
  @@map("device_sessions")
}

// =============================================================================
// AUTH.JS ADAPTER TABLES (preserved from Phase 1)
// =============================================================================

/// Auth.js v5 polymorphic account link. Connects OAuth/credential providers
/// to the role-specific user tables (PlatformAdmin was replaced by Admin above).
model Account {
  id                String  @id @default(uuid())
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  adminId           String?
  admin             Admin?           @relation(fields: [adminId], references: [id])
  restaurantOwnerId String?
  restaurantOwner   RestaurantOwner? @relation(fields: [restaurantOwnerId], references: [id])
  staffId           String?
  staff             RestaurantStaff? @relation(fields: [staffId], references: [id])
  customerId        String?
  customer          Customer?        @relation(fields: [customerId], references: [id])

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// Auth.js v5 server-side session (used when switching to database strategy).
model AuthSession {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  /// Role and userId denormalised for fast middleware lookups
  userRole     UserRole
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([expires])
  @@map("auth_sessions")
}

/// Auth.js v5 OTP / magic-link verification tokens.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// PHASE 5 — Check-in System
// =============================================================================

/// Dynamic QR code token for a branch.
/// A new token is generated on each rotation interval.
/// The `tokenHash` is SHA-256(secret + branchId + issuedAt) — never stored plain.
model RestaurantQRCode {
  id          String   @id @default(uuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  /// SHA-256 hash of the signed token value — used for validation
  tokenHash   String   @unique
  /// Signed JWT token value returned to the dashboard (display only, not stored plain)
  /// We store the hash above; this field is null in DB, set only in API response
  isActive    Boolean  @default(true)
  issuedAt    DateTime @default(now())
  expiresAt   DateTime
  /// How many times this token has been successfully used (should stay ≤ 1 per design)
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([branchId, isActive])
  @@index([expiresAt])
  @@map("restaurant_qr_codes")
}

/// Physical NFC tag registered to a branch.
/// The tag's UID is AES-256-GCM encrypted before storage.
model RestaurantNFCTag {
  id              String   @id @default(uuid())
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id])
  label           String?
  /// AES-256-GCM ciphertext of the raw NFC UID
  encryptedUid    String   @unique
  /// HMAC-SHA256 of the raw UID — used for fast lookup without decryption
  uidHash         String   @unique
  isActive        Boolean  @default(true)
  registeredAt    DateTime @default(now())
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([branchId, isActive])
  @@map("restaurant_nfc_tags")
}

/// Immutable log of every check-in attempt (success and failure).
/// Separate from CheckInSession so failures are also auditable.
model CheckInLog {
  id            String        @id @default(uuid())
  branchId      String
  branch        Branch        @relation(fields: [branchId], references: [id])
  customerId    String?
  method        CheckInMethod
  /// Whether the attempt was accepted
  success       Boolean
  /// Reason for failure if success = false
  failReason    String?
  /// Hashed device fingerprint presented
  deviceHash    String?
  ipAddress     String?
  /// ID of the RestaurantVisit created on success
  visitId       String?
  occurredAt    DateTime      @default(now())

  @@index([branchId, occurredAt])
  @@index([customerId])
  @@index([success, occurredAt])
  @@map("check_in_logs")
}

/// Device fingerprint record for fraud/duplicate detection.
/// One row per (hash, customer). Updated on each visit.
model DeviceFingerprint {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  /// SHA-256 of (userAgent + screenRes + timezone + language)
  fingerprintHash String
  userAgent    String?
  ipAddress    String?
  lastSeenAt   DateTime @default(now())
  seenCount    Int      @default(1)
  createdAt    DateTime @default(now())

  @@unique([customerId, fingerprintHash])
  @@index([fingerprintHash])
  @@map("device_fingerprints")
}

// =============================================================================
// PHASE 6 — Game Engine additions
// =============================================================================

/// Personal best score per customer per game (across all branches of a group).
/// Updated atomically whenever a higher validated score is submitted.
model PersonalBest {
  id        String   @id @default(uuid())
  score     Int
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id])

  @@unique([customerId, gameId])
  @@index([customerId])
  @@index([gameId, score])
  @@map("personal_bests")
}

// =============================================================================
// PHASE 7 — Leaderboard & Competitive Scoring additions
// =============================================================================

/// Type of leaderboard period
enum LeaderboardPeriod {
  DAILY
  WEEKLY
  MONTHLY
  LIFETIME
}

/// Per-group leaderboard configuration: chain-wide vs branch-scoped, active types
model LeaderboardConfig {
  id                    String   @id @default(uuid())
  /// Whether the chain-wide leaderboard is active (chains only)
  chainWideEnabled      Boolean  @default(false)
  /// Which period types are enabled
  dailyEnabled          Boolean  @default(true)
  weeklyEnabled         Boolean  @default(true)
  monthlyEnabled        Boolean  @default(true)
  lifetimeEnabled       Boolean  @default(true)
  /// Max entries shown on public leaderboard
  displayTopN           Int      @default(10)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  restaurantGroupId String          @unique
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@map("leaderboard_configs")
}

/// Entries for the weekly leaderboard header (one per customer per week).
model WeeklyLeaderboardEntry {
  id        String   @id @default(uuid())
  points    Int      @default(0)
  rank      Int?
  gamesPlayed Int    @default(0)
  updatedAt DateTime @updatedAt

  leaderboardId String
  leaderboard   WeeklyLeaderboard @relation(fields: [leaderboardId], references: [id])
  customerId    String
  customer      Customer          @relation(fields: [customerId], references: [id])

  @@unique([leaderboardId, customerId])
  @@index([leaderboardId, points])
  @@index([customerId])
  @@map("weekly_leaderboard_entries")
}

/// Monthly leaderboard header — one per (group, month start date).
model MonthlyLeaderboard {
  id             String   @id @default(uuid())
  /// First day of the month (UTC midnight)
  monthStartDate DateTime
  isFrozen       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  entries MonthlyLeaderboardEntry[]

  @@unique([restaurantGroupId, monthStartDate])
  @@index([restaurantGroupId, monthStartDate])
  @@map("monthly_leaderboards")
}

/// One row per customer per monthly leaderboard.
model MonthlyLeaderboardEntry {
  id          String   @id @default(uuid())
  points      Int      @default(0)
  rank        Int?
  gamesPlayed Int      @default(0)
  updatedAt   DateTime @updatedAt

  leaderboardId String
  leaderboard   MonthlyLeaderboard @relation(fields: [leaderboardId], references: [id])
  customerId    String
  customer      Customer           @relation(fields: [customerId], references: [id])

  @@unique([leaderboardId, customerId])
  @@index([leaderboardId, points])
  @@index([customerId])
  @@map("monthly_leaderboard_entries")
}

/// One row per customer in the lifetime leaderboard for a group.
model LifetimeLeaderboardEntry {
  id          String   @id @default(uuid())
  points      Int      @default(0)
  rank        Int?
  gamesPlayed Int      @default(0)
  updatedAt   DateTime @updatedAt

  leaderboardId String
  leaderboard   LifetimeLeaderboard @relation(fields: [leaderboardId], references: [id])
  customerId    String
  customer      Customer            @relation(fields: [customerId], references: [id])

  @@unique([leaderboardId, customerId])
  @@index([leaderboardId, points])
  @@index([customerId])
  @@map("lifetime_leaderboard_entries")
}

/// Suspicious activity log for the leaderboard anti-cheat review queue.
model LeaderboardFlag {
  id          String   @id @default(uuid())
  reason      String
  details     String?
  isResolved  Boolean  @default(false)
  resolvedBy  String?  // Admin ID
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id])
  restaurantGroupId   String

  @@index([customerId])
  @@index([restaurantGroupId, isResolved])
  @@index([createdAt])
  @@map("leaderboard_flags")
}

// =============================================================================
// PHASE 8 — Rewards, Spin Wheel & Prize Redemption additions
// =============================================================================

/// Spin eligibility rules
enum SpinEligibility {
  ONE_PER_VISIT
  ONE_PER_DAY
  MIN_GAME_SCORE
}

/// Per-group spin wheel configuration.
model SpinWheelConfig {
  id                    String          @id @default(uuid())
  isEnabled             Boolean         @default(true)
  eligibility           SpinEligibility @default(ONE_PER_VISIT)
  /// Minimum game score required (only for MIN_GAME_SCORE eligibility)
  minScoreRequired      Int             @default(0)
  /// Custom daily spin limit (for ONE_PER_DAY, this overrides default of 1)
  dailySpinLimit        Int             @default(1)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  restaurantGroupId String          @unique
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@map("spin_wheel_configs")
}

/// Leaderboard reward rules — auto-issued at end of period.
model LeaderboardRewardRule {
  id         String   @id @default(uuid())
  /// Period this rule applies to (DAILY, WEEKLY, MONTHLY)
  period     LeaderboardPeriod
  /// Rank range: e.g. minRank=1, maxRank=1 means "1st place"
  minRank    Int
  maxRank    Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rewardId          String
  reward            Reward          @relation(fields: [rewardId], references: [id])
  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@index([restaurantGroupId, period])
  @@map("leaderboard_reward_rules")
}

/// History of leaderboard prizes issued to winners.
model WinnerHistory {
  id         String   @id @default(uuid())
  period     LeaderboardPeriod
  periodDate DateTime
  rank       Int
  createdAt  DateTime @default(now())

  customerId        String
  customer          Customer        @relation(fields: [customerId], references: [id])
  rewardId          String
  reward            Reward          @relation(fields: [rewardId], references: [id])
  rewardClaimId     String?
  restaurantGroupId String

  @@index([restaurantGroupId, period, periodDate])
  @@index([customerId])
  @@map("winner_history")
}

