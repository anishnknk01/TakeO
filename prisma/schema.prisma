}

// =============================================================================
// PHASE 10 — SaaS Billing, Onboarding & Infrastructure
// =============================================================================

/// Payment provider enum — extensible for multiple gateways.
enum PaymentProvider {
  STRIPE
  RAZORPAY
  PAYPAL
  MANUAL
}

/// Invoice status.
enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  PAST_DUE
  VOID
  UNCOLLECTIBLE
}

/// Invoice record generated on each billing cycle or plan change.
model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  status          InvoiceStatus @default(DRAFT)
  /// Amount in smallest currency unit
  amountDue       Int
  amountPaid      Int           @default(0)
  currency        String        @default("usd")
  /// Tax amount (cents)
  taxAmount       Int           @default(0)
  /// Coupon discount applied (cents)
  discountAmount  Int           @default(0)
  /// External provider invoice ID
  externalId      String?
  provider        PaymentProvider @default(MANUAL)
  periodStart     DateTime
  periodEnd       DateTime
  paidAt          DateTime?
  dueAt           DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  subscriptionId    String
  subscription      Subscription @relation(fields: [subscriptionId], references: [id])
  restaurantGroupId String

  paymentEvents PaymentEvent[]

  @@index([restaurantGroupId])
  @@index([status])
  @@index([dueAt])
  @@map("invoices")
}

/// Individual payment attempt / event log for an invoice.
model PaymentEvent {
  id           String          @id @default(uuid())
  provider     PaymentProvider
  eventType    String          // e.g. "charge.succeeded", "charge.failed"
  /// External event/charge ID from the payment provider
  externalId   String?
  amount       Int
  currency     String          @default("usd")
  status       String          // "succeeded", "failed", "pending"
  failReason   String?
  metadata     Json?
  occurredAt   DateTime        @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([occurredAt])
  @@map("payment_events")
}

/// Billing coupon code for discounts on subscriptions.
model BillingCoupon {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  /// Discount type: 'percent' or 'fixed'
  discountType  String    @default("percent")
  /// Discount value (percent 0-100 or fixed amount in cents)
  discountValue Int
  /// Max redemptions total
  maxUses       Int?
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
  @@map("billing_coupons")
}

/// Tracks onboarding progress for new restaurant owners.
model OnboardingProgress {
  id                    String   @id @default(uuid())
  step                  Int      @default(1)
  /// Steps completed as a JSON array of step names
  completedSteps        Json     @default("[]")
  isComplete            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  restaurantGroupId String          @unique
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@map("onboarding_progress")
}

/// Notification delivery record.
model NotificationDelivery {
  id          String   @id @default(uuid())
  channel     NotificationChannel
  eventType   String   // e.g. "otp", "reward_won", "subscription_renewal"
  recipient   String   // phone or email
  subject     String?
  body        String
  status      String   @default("pending") // "pending", "sent", "failed"
  sentAt      DateTime?
  failReason  String?
  createdAt   DateTime @default(now())

  restaurantGroupId String?

  @@index([eventType, createdAt])
  @@index([status])
  @@map("notification_deliveries")
}

// =============================================================================
// V2 GROWTH FEATURES
// =============================================================================

// ─── Feature 1 & 2: Challenges & Missions ────────────────────────────────────

enum ChallengeType {
  PLAY_GAMES
  VISIT_COUNT
  SCORE_ABOVE
  REFER_FRIEND
  BIRTHDAY
  WEEKEND
  CUSTOM
}

enum ChallengePeriod {
  DAILY
  WEEKLY
  MONTHLY
  FESTIVAL
  ONE_TIME
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

/// A challenge/mission definition created by a restaurant owner.
model Challenge {
  id              String          @id @default(uuid())
  name            String
  description     String?
  type            ChallengeType
  period          ChallengePeriod
  /// JSON criteria e.g. {"targetCount":5,"gameId":"xxx","minScore":10000}
  criteria        Json
  /// Reward issued on completion
  rewardId        String?
  reward          Reward?         @relation(fields: [rewardId], references: [id])
  /// Bonus points awarded on completion
  bonusPoints     Int             @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  progress ChallengeProgress[]

  @@index([restaurantGroupId, isActive])
  @@index([period])
  @@map("challenges")
}

/// Tracks a customer's progress toward completing a challenge.
model ChallengeProgress {
  id            String          @id @default(uuid())
  currentValue  Int             @default(0)
  targetValue   Int
  status        ChallengeStatus @default(ACTIVE)
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])

  @@unique([challengeId, customerId])
  @@index([customerId, status])
  @@map("challenge_progress")
}

// ─── Feature 3: Referral System ──────────────────────────────────────────────

model Referral {
  id           String   @id @default(uuid())
  code         String   @unique
  /// Bonus points given to referrer on successful referral
  referrerBonus Int     @default(100)
  /// Bonus points given to referred customer
  refereeBonus  Int     @default(50)
  usedCount    Int      @default(0)
  maxUses      Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  referrerId        String
  referrer          Customer @relation("ReferralsMade", fields: [referrerId], references: [id])
  restaurantGroupId String

  referees ReferralRedemption[]

  @@index([referrerId])
  @@index([code])
  @@map("referrals")
}

model ReferralRedemption {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())

  referralId String
  referral   Referral @relation(fields: [referralId], references: [id])
  refereeId  String
  referee    Customer @relation("ReferralsReceived", fields: [refereeId], references: [id])

  @@unique([referralId, refereeId])
  @@map("referral_redemptions")
}

// ─── Feature 4 & 5: Tournaments & Team Battles ───────────────────────────────

enum TournamentType {
  DAILY
  WEEKEND
  FESTIVAL
  TEAM
}

enum TournamentStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Tournament {
  id          String           @id @default(uuid())
  name        String
  description String?
  type        TournamentType
  status      TournamentStatus @default(UPCOMING)
  gameId      String?
  startsAt    DateTime
  endsAt      DateTime
  entryFee    Int              @default(0)
  prizePool   Json?
  maxPlayers  Int?
  isTeamBased Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  participants TournamentParticipant[]
  teams        TournamentTeam[]

  @@index([restaurantGroupId, status])
  @@index([startsAt])
  @@map("tournaments")
}

model TournamentParticipant {
  id        String   @id @default(uuid())
  score     Int      @default(0)
  rank      Int?
  joinedAt  DateTime @default(now())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  teamId       String?
  team         TournamentTeam? @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, customerId])
  @@index([tournamentId, score])
  @@map("tournament_participants")
}

model TournamentTeam {
  id          String   @id @default(uuid())
  name        String
  totalScore  Int      @default(0)
  createdAt   DateTime @default(now())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  members TournamentParticipant[]

  @@index([tournamentId, totalScore])
  @@map("tournament_teams")
}

// ─── Feature 6: Seasonal Events ──────────────────────────────────────────────

model SeasonalEvent {
  id          String   @id @default(uuid())
  name        String
  description String?
  theme       String?
  imageUrl    String?
  startsAt    DateTime
  endsAt      DateTime
  /// JSON config for special rules (2x points, special prizes, etc.)
  config      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@index([restaurantGroupId, startsAt])
  @@map("seasonal_events")
}

// ─── Feature 7: Lucky Hours ──────────────────────────────────────────────────

enum LuckyHourType {
  DOUBLE_POINTS
  DOUBLE_SPINS
  BONUS_REWARDS
  MULTIPLIER
}

model LuckyHour {
  id          String        @id @default(uuid())
  name        String
  type        LuckyHourType
  multiplier  Float         @default(2.0)
  /// Days of week (0=Sun, 6=Sat) as JSON array [1,2,3,4,5]
  daysOfWeek  Json          @default("[1,2,3,4,5]")
  startTime   String        // HH:MM format
  endTime     String        // HH:MM format
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@index([restaurantGroupId, isActive])
  @@map("lucky_hours")
}

// ─── Feature 8: AI Recommendation Engine ─────────────────────────────────────

/// Stores AI-generated recommendations per customer.
model AIRecommendation {
  id            String   @id @default(uuid())
  /// Type: "game", "reward", "campaign_time", "churn_risk"
  type          String
  /// JSON payload with recommendation details
  payload       Json
  score         Float    @default(0)
  isActioned    Boolean  @default(false)
  createdAt     DateTime @default(now())

  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  restaurantGroupId String

  @@index([restaurantGroupId, type])
  @@index([customerId])
  @@map("ai_recommendations")
}

// ─── Feature 9: Marketing Center ─────────────────────────────────────────────

enum CampaignChannel {
  SMS
  EMAIL
  PUSH
  IN_APP
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

model Campaign {
  id            String          @id @default(uuid())
  name          String
  channel       CampaignChannel
  status        CampaignStatus  @default(DRAFT)
  subject       String?
  body          String
  /// Target audience filter (JSON)
  audienceFilter Json?
  scheduledAt   DateTime?
  sentAt        DateTime?
  recipientCount Int            @default(0)
  openRate      Float?
  clickRate     Float?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@index([restaurantGroupId, status])
  @@index([scheduledAt])
  @@map("campaigns")
}

// ─── Feature 10: Customer Levels ─────────────────────────────────────────────

enum CustomerLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

/// Level thresholds and benefits per restaurant group.
model LevelConfig {
  id              String        @id @default(uuid())
  level           CustomerLevel
  minPoints       Int
  /// JSON benefits e.g. {"spinMultiplier":2,"exclusiveRewards":["id1"]}
  benefits        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@unique([restaurantGroupId, level])
  @@map("level_configs")
}

// ─── Feature 11: Digital Wallet ──────────────────────────────────────────────

enum WalletItemType {
  POINTS
  COUPON
  GIFT_CARD
  REWARD
  BADGE
}

model WalletItem {
  id          String         @id @default(uuid())
  type        WalletItemType
  /// Display label
  label       String
  /// Value (points amount, coupon value, etc.)
  value       Int            @default(0)
  /// Reference ID (rewardClaimId, couponId, etc.)
  referenceId String?
  isUsed      Boolean        @default(false)
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, type, isUsed])
  @@map("wallet_items")
}

// ─── Feature 12: Achievement System ──────────────────────────────────────────

model Achievement {
  id          String   @id @default(uuid())
  name        String
  description String?
  iconUrl     String?
  /// Criteria as JSON e.g. {"type":"games_played","target":100}
  criteria    Json
  /// Points awarded on unlock
  pointsReward Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurantGroupId String?
  restaurantGroup   RestaurantGroup? @relation(fields: [restaurantGroupId], references: [id])

  unlocks AchievementUnlock[]

  @@index([restaurantGroupId])
  @@map("achievements")
}

model AchievementUnlock {
  id         String   @id @default(uuid())
  unlockedAt DateTime @default(now())

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])

  @@unique([achievementId, customerId])
  @@index([customerId])
  @@map("achievement_unlocks")
}

// ─── Feature 13: POS Integration ─────────────────────────────────────────────

model POSIntegration {
  id          String   @id @default(uuid())
  provider    String   // e.g. "square", "toast", "clover"
  apiKey      String?  // encrypted
  webhookUrl  String?
  isActive    Boolean  @default(false)
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@unique([restaurantGroupId, provider])
  @@map("pos_integrations")
}

// ─── Feature 14: White Label ─────────────────────────────────────────────────

model WhiteLabelConfig {
  id             String   @id @default(uuid())
  customDomain   String?  @unique
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String   @default("#c026d3")
  secondaryColor String   @default("#171717")
  appName        String   @default("PlayBite")
  hidePlayBiteBranding Boolean @default(false)
  customCss      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  restaurantGroupId String          @unique
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@map("white_label_configs")
}

// ─── Feature 15: Marketplace ─────────────────────────────────────────────────

enum MarketplaceItemType {
  GAME
  THEME
  REWARD_TEMPLATE
  MARKETING_TEMPLATE
}

model MarketplaceItem {
  id          String              @id @default(uuid())
  type        MarketplaceItemType
  name        String
  description String?
  thumbnailUrl String?
  price       Int                 @default(0) // cents, 0 = free
  version     String              @default("1.0.0")
  /// JSON config / template payload
  payload     Json?
  downloads   Int                 @default(0)
  rating      Float               @default(0)
  isPublished Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  authorId String? // Admin or partner ID

  installations MarketplaceInstall[]

  @@index([type, isPublished])
  @@map("marketplace_items")
}

model MarketplaceInstall {
  id          String   @id @default(uuid())
  installedAt DateTime @default(now())

  itemId            String
  item              MarketplaceItem @relation(fields: [itemId], references: [id])
  restaurantGroupId String

  @@unique([itemId, restaurantGroupId])
  @@index([restaurantGroupId])
  @@map("marketplace_installs")
}

// =============================================================================
// PHASE 12 — Enterprise Platform
// =============================================================================

// ─── 1. Multi-Country Support ────────────────────────────────────────────────

model CountryConfig {
  id          String   @id @default(uuid())
  countryCode String   @unique // ISO 3166-1 alpha-2
  countryName String
  currency    String   @default("USD") // ISO 4217
  locale      String   @default("en")
  taxRate     Float    @default(0)
  taxName     String   @default("VAT")
  timezone    String   @default("UTC")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("country_configs")
}

// ─── 3. Enterprise Security — SSO & API Keys ─────────────────────────────────

enum SSOProvider {
  SAML
  OAUTH
  OIDC
}

model SSOConfig {
  id           String      @id @default(uuid())
  provider     SSOProvider
  /// Identity provider metadata URL or XML
  metadataUrl  String?
  clientId     String?
  clientSecret String?     // encrypted
  issuer       String?
  callbackUrl  String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@unique([restaurantGroupId, provider])
  @@map("sso_configs")
}

model IPRestriction {
  id        String   @id @default(uuid())
  /// CIDR notation or single IP
  cidr      String
  isAllow   Boolean  @default(true) // true=allow, false=deny
  createdAt DateTime @default(now())

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@index([restaurantGroupId])
  @@map("ip_restrictions")
}

// ─── 5. Developer Platform — API Keys & Webhooks ─────────────────────────────

model APIKey {
  id          String   @id @default(uuid())
  name        String
  /// SHA-256 hash of the key (never store plaintext)
  keyHash     String   @unique
  /// Prefix shown to user (first 8 chars)
  keyPrefix   String
  scopes      Json     @default("[\"read\"]") // ["read","write","admin"]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@index([restaurantGroupId])
  @@index([keyHash])
  @@map("api_keys")
}

model WebhookEndpoint {
  id          String   @id @default(uuid())
  url         String
  /// Events to deliver e.g. ["visit.created","score.submitted"]
  events      Json     @default("[]")
  /// Secret used to sign payloads (HMAC-SHA256)
  secret      String
  isActive    Boolean  @default(true)
  lastDeliveryAt DateTime?
  failCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  deliveries WebhookDelivery[]

  @@index([restaurantGroupId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id          String   @id @default(uuid())
  event       String
  payload     Json
  httpStatus  Int?
  response    String?
  success     Boolean  @default(false)
  attemptCount Int     @default(1)
  deliveredAt DateTime @default(now())

  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([endpointId, deliveredAt])
  @@map("webhook_deliveries")
}

// ─── 4. Integration Hub ──────────────────────────────────────────────────────

enum IntegrationType {
  POS
  CRM
  ERP
  MARKETING
  PAYMENT
  CUSTOM
}

model Integration {
  id          String          @id @default(uuid())
  type        IntegrationType
  provider    String          // e.g. "salesforce", "hubspot", "square"
  name        String
  config      Json?           // encrypted connection details
  isActive    Boolean         @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  restaurantGroupId String
  restaurantGroup   RestaurantGroup @relation(fields: [restaurantGroupId], references: [id])

  @@unique([restaurantGroupId, type, provider])
  @@map("integrations")
}

// ─── 9. Compliance — GDPR ────────────────────────────────────────────────────

enum DataRequestType {
  EXPORT
  DELETION
}

enum DataRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model DataRequest {
  id          String            @id @default(uuid())
  type        DataRequestType
  status      DataRequestStatus @default(PENDING)
  /// Requesting user identity
  requesterId String
  requesterEmail String?
  /// Download URL (for export requests)
  resultUrl   String?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  restaurantGroupId String?

  @@index([status])
  @@index([requesterId])
  @@map("data_requests")
}

model ConsentRecord {
  id          String   @id @default(uuid())
  consentType String   // "marketing", "analytics", "cookies"
  isGranted   Boolean
  ipAddress   String?
  userAgent   String?
  grantedAt   DateTime @default(now())
  revokedAt   DateTime?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, consentType])
  @@map("consent_records")
}

// ─── 8. Monitoring ───────────────────────────────────────────────────────────

model SystemMetric {
  id          String   @id @default(uuid())
  name        String   // "api_latency_p95", "error_rate", "active_connections"
  value       Float
  unit        String?  // "ms", "percent", "count"
  tags        Json?    // {"endpoint":"/api/games/start","region":"us-east-1"}
  recordedAt  DateTime @default(now())

  @@index([name, recordedAt])
  @@map("system_metrics")
}
